  m_Name: Stage2Dialog 1
  m_EditorClassIdentifier: Assembly-CSharp::MainSystem.Dialog.DialogSO
  DialogContent: "\u3088\u3046\uFF01{\\n}\u660E\u65E5\u884C\u304F\u306E\u306F\u3069\u3053\u304B\u899A\u3048\u3066\u308B\u304B\uFF1F\\n\u3082\u3061\u308D\u3093\u3042\u305D\u3053\u3060\u305C\uFF1F{\\n}\u6D77\uFF01\u6700\u9AD8\u3060\u305C\uFF01{\\n}\u9053\u5177\u306F\u5BB6\u306B\u7528\u610F\u3057\u3068\u3044\u305F\u304B\u3089\\n\u6301\u3063\u3066\u304D\u3066\u304F\u308C\uFF01{\\n}\u307E\u305A\u30D3\u30FC\u30C1\u3067\u5C65\u304F\u30A2\u30EC\\n\u3053\u308C\u304C\u306A\u3044\u3068\u8DB3\u304C\u30A2\u30C1\u30C1\u3060\u305C\uFF1F{\\n}\u6B21\u306B\u30D3\u30FC\u30C1\u30DC\u30FC\u30EB\\n\u3053\u308C\u304C\u3042\u308C\u3070\u30C1\u30E3\u30F3\u30CD\u30FC\u3068\u30A6\u30D5\u30D5\u3060\u305C\uFF1F{\\n}\u305D\u308C\u304B\u3089\u65E5\u9670\u3092\u4F5C\u308B\u30A2\u30EC\\n\u6D77\u306F\u306F\u3057\u3083\u3050\u3060\u3051\u3058\u3083\u306A\u3044\u3093\u3060\u305C\uFF1F{\\n}\u3042\u3068\u306F\u2026\u2026\\n\u6CE2\u306B\u4E57\u308B\u30A2\u30EC\uFF01{\\n}\u96A3\u306E\u8FB2\u5BB6\u306E\u30B8\u30B8\u30A4\u3093\u3068\u3053\u304B\u3089\\n\u3061\u3087\u3063\u304F\u3089\u62DD\u501F\u3057\u3066\u304D\u305F\u305C\uFF01{\\n}\u53BB\u5E74\u306F\u30C8\u30E9\u30AF\u30BF\u30FC\u3067\u8FFD\u3044\u56DE\u3055\u308C\u305F\u3051\u3069\\n\u591A\u5206\u5927\u4E08\u592B\u3060\u305C{\\n}\u3058\u3083\u3042\u6D77\u3092\u697D\u3057\u3082\u3046\u305C\uFF01"
  RushIntroContent: "\u9045\u523B\u3060\u30FC\u30FC\uFF01\uFF01{\\n}\u3042\uFF01\u5FD8\u308C\u7269\uFF01\uFF01"
